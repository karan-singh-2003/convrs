{
  "name": "web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others \"next dev --turbopack --port 8888\" \"pnpm prisma:studio\"",
    "build": "pnpm prisma:generate && next build",
    "lint": "next lint",
    "start": "next start",
    "test": "pnpm prisma:generate && vitest -no-file-parallelism --bail=1",
    "prisma:generate": "dotenv-flow -e .env -- pnpm --filter=@repo/db prisma:generate",
    "prisma:push": "dotenv-flow -e .env -- pnpm --filter=@repo/db prisma:push",
    "prisma:studio": "dotenv-flow -e .env -- pnpm --filter=@repo/db prisma:studio",
    "prisma:format": "dotenv-flow -e .env -- pnpm --filter=@repo/db format"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@boxyhq/saml-jackson": "1.52.1",
    "@chronark/zod-bird": "^1.0.0",
    "@date-fns/tz": "^1.4.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@github/webauthn-json": "^2.1.1",
    "@hookform/resolvers": "^5.2.2",
    "@number-flow/react": "^0.5.11",
    "@prisma/client": "^7.3.0",
    "@prisma/nextjs-monorepo-workaround-plugin": "^7.3.0",
    "@repo/analytics": "workspace:*",
    "@repo/db": "workspace:*",
    "@repo/email": "workspace:*",
    "@repo/tailwind-config": "workspace:*",
    "@repo/ui": "workspace:*",
    "@repo/utils": "workspace:*",
    "@sindresorhus/slugify": "^3.0.0",
    "@stripe/stripe-js": "^7.3.1",
    "@tanstack/react-table": "^8.21.3",
    "@teamhanko/hanko-elements": "^2.4.0",
    "@teamhanko/passkeys-next-auth-provider": "^0.3.1",
    "@upstash/qstash": "^2.9.0",
    "@upstash/redis": "^1.36.1",
    "@vercel/functions": "^3.3.6",
    "aws4fetch": "^1.0.20",
    "base-x": "^5.0.1",
    "bcryptjs": "^3.0.3",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "date-fns": "^4.1.0",
    "dodopayments": "^2.28.2",
    "fastify": "^4.29.1",
    "file-type": "^21.3.0",
    "framer-motion": "^12.26.2",
    "input-otp": "^1.4.2",
    "jose": "^6.1.3",
    "lucide-react": "^0.462.0",
    "mapbox-gl": "^3.20.0",
    "next": "^16.1.4",
    "next-auth": "^4.24.13",
    "next-safe-action": "^8.0.11",
    "openid-client": "^6.8.1",
    "otpauth": "^9.5.0",
    "pg": "8.16.0",
    "qr-code-styling": "^1.9.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.1",
    "react-virtualized-auto-sizer": "^1.0.25",
    "react-window": "^1.8.7",
    "shiki": "^3.22.0",
    "sonner": "^1.7.3",
    "stripe": "^20.3.1",
    "swr": "^2.3.8",
    "ws": "^8.20.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "dotenv-flow": "^4.1.0",
    "dotenv-flow-cli": "^1.1.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.5.9",
    "postcss": "^8.4.49",
    "prettier": "3.8.0",
    "tailwindcss": "^3.4.17",
    "typescript": "5.9.2"
  },
  "browser": {
    "crypto": "false"
  }
}
