{
  "name": "@repo/analytics",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./src/index.ts",
  "files": [
    "dist/**"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@repo/db": "workspace:*",
    "@repo/email": "workspace:*",
    "@repo/utils": "workspace:*",
    "fastify": "^4.29.1",
    "react": "^19.2.5",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "19.2.3",
    "tsup": "^6.1.3",
    "typescript": "5.9.2"
  }
}
