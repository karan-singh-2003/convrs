enum BillingInterval {
  month
  year
}

enum SubscriptionStatus {
  inactive
  trialing
  active
  past_due
  canceling
  canceled
  expired
}

enum WorkspacePlan {
  free
  starter
  basic
  pro
  growth
  business
  scale
  pro_plus
  enterprise
  ultimate
}

model Workspace {
  id String @id @default(cuid())

  name   String
  slug   String  @unique
  logo   String?
  domain String?

  inviteCode String? @unique
  isPublic   Boolean @default(false)
  publicId   String? @unique

  ssoEmailDomain String?   @unique
  ssoEnforcedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usage            Int      @default(0)
  tierEvents       Int      @default(0)
  usageLimit       Int      @default(0)
  usageLastChecked DateTime @default(now())

  invoicePrefix   String?   @unique
  paymentFailedAt DateTime?

  webhookEnabled Boolean @default(false)

  projectToken String? @unique

  dodoCustomerId     String?            @unique
  dodoSubscriptionId String?            @unique
  subscriptionStatus SubscriptionStatus @default(inactive)
  billingInterval    BillingInterval?

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  freeTrialEndDate   DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)

  blockedHostnames   String[]      @default([])
  blockedIpAddresses String[]      @default([])
  blockedPages       String[]      @default([])
  plan               WorkspacePlan @default(free)

  stripeIntegration StripeIntegration?

  invoices         Invoice[]
  restrictedTokens RestrictedToken[]
  sentEmails       SentEmail[]
  webhooks         Webhook[]
  invites          WorkspaceInvite[]
  users            WorkspaceUsers[]
  funnels          Funnel[]
  alerts           Alert[]
  customers        Customer[]
  payments Payment[]

  @@index([usageLastChecked])
  @@index([dodoSubscriptionId])
  @@index([dodoCustomerId])
  @@index([subscriptionStatus])
  @@index([plan])
}

model WorkspaceInvite {
  email       String
  expires     DateTime
  workspaceId String
  role        WorkspaceRole @default(member)
  createdAt   DateTime      @default(now())
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([email, workspaceId])
  @@index([workspaceId])
}

model WorkspaceUsers {
  id                   String        @id @default(cuid())
  role                 WorkspaceRole @default(member)
  userId               String
  workspaceId          String
  workspacePreferences Json?
  defaultFolderId      String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace            Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

model SentEmail {
  id          String     @id @default(cuid())
  type        String
  createdAt   DateTime   @default(now())
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

enum FunnelStepType {
  goal
  page_view
}

model Funnel {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  steps     FunnelStep[]

  @@index([workspaceId])
}

model FunnelStep {
  id        String         @id @default(cuid())
  funnelId  String
  name      String
  value     String
  type      FunnelStepType
  order     Int
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  funnel Funnel @relation(fields: [funnelId], references: [id], onDelete: Cascade)

  @@unique([funnelId, order])
  @@index([funnelId])
}

enum WorkspaceRole {
  owner
  member
  viewer
  billing
}
