model Invoice {
  id                   String         @id @default(cuid())
  programId            String?
  workspaceId          String
  number               String?        @unique
  status               InvoiceStatus  @default(processing)
  paymentMethod        PaymentMethod?
  amount               Int            @default(0)
  fee                  Int            @default(0)
  total                Int            @default(0)
  externalAmount       Int            @default(0)
  receiptUrl           String?
  failedReason         String?
  registeredDomains    Json?          @db.Json
  stripeChargeMetadata Json?          @db.Json
  failedAttempts       Int            @default(0)
  createdAt            DateTime       @default(now())
  paidAt               DateTime?
  workspace            Workspace      @relation(fields: [workspaceId], references: [id])

  @@index([programId])
  @@index([workspaceId])
}

enum InvoiceStatus {
  processing
  completed
  failed
}

enum PaymentMethod {
  card
  ach
  ach_fast
  sepa
  acss
}
