enum AttributionStatus {
  pending
  attributed
  unattributed
}

model Customer {
  id                     String            @id @default(cuid())
  name                   String?
  email                  String?
  avatar                 String?           @db.Text
  externalId             String?
  stripeCustomerId       String?           @unique
  country                String?
  sales                  Int               @default(0)
  saleAmount             BigInt            @default(0)
  firstSaleAt            DateTime?
  subscriptionCanceledAt DateTime?
  workspaceId            String
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  device                 String?
  browser                String?

  // Attribution tracking
  attributionStatus      AttributionStatus @default(pending)
  attributedAt           DateTime?
  lastAttributionAttempt DateTime?
  visitorId              String?           // the analytics visitor_id that attributed

  workspace              Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  payments               Payment[]

  @@unique([workspaceId, externalId])
  @@index([workspaceId, email])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, saleAmount])
  @@index([workspaceId, attributionStatus])
}