{
  "name": "@repo/email",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "clean": "rm -rf .turbo node_modules",
    "dev": "email dev --dir ./src/templates -p 3333",
    "build": "tsup",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@react-email/components": "^1.0.2",
    "@react-email/font": "0.0.10",
    "@react-email/markdown": "^0.0.17",
    "@react-email/render": "^2.0.0",
    "@repo/utils": "workspace:*",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.462.0",
    "nodemailer": "^6.9.3",
    "react-email": "5.2.5",
    "resend": "6.6.0"
  },
  "devDependencies": {
    "@react-email/preview-server": "5.2.5",
    "@types/node": "^22.15.3",
    "@types/nodemailer": "~6.4.17",
    "@types/react": "19.2.3",
    "@types/react-dom": "19.2.3",
    "tsup": "^6.1.3",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./templates/*": {
      "types": "./dist/templates/*.d.ts",
      "import": "./dist/templates/*.mjs",
      "require": "./dist/templates/*.js"
    },
    "./resend": {
      "types": "./dist/resend/index.d.ts",
      "import": "./dist/resend/index.mjs",
      "require": "./dist/resend/index.js"
    },
    "./resend/*": {
      "types": "./dist/resend/*.d.ts",
      "import": "./dist/resend/*.mjs",
      "require": "./dist/resend/*.js"
    },
    "./send-via-nodemailer": {
      "types": "./dist/send-via-nodemailer.d.ts",
      "import": "./dist/send-via-nodemailer.mjs",
      "require": "./dist/send-via-nodemailer.js"
    },
    "./send-via-resend": {
      "types": "./dist/send-via-resend.d.ts",
      "import": "./dist/send-via-resend.mjs",
      "require": "./dist/send-via-resend.js"
    }
  }
}
